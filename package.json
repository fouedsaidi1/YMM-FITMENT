{
    "name": "ymm-shopify-app",
    "private": true,
    "scripts": {
        "build": "remix vite:build",
        "dev": "remix vite:dev --port 3000",
        "shopify:dev": "shopify app dev --store foued-dev.myshopify.com",
        "dev:remix": "remix vite:dev --port 3000",
        "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
        "setup": "prisma generate && prisma migrate deploy",
        "start": "remix-serve ./build/server/index.js",
        "typecheck": "tsc"
    },
    "type": "module",
    "engines": {
        "node": "^18.20 || ^20.10 || >=21.0.0"
    },
    "dependencies": {
        "@prisma/client": "^5.9.1",
        "@remix-run/node": "^2.5.1",
        "@remix-run/react": "^2.5.1",
        "@remix-run/serve": "^2.5.1",
        "@shopify/app": "^3.58.2",
        "@shopify/app-bridge-react": "^4.1.6",
        "@shopify/polaris": "^12.0.0",
        "@shopify/shopify-app-remix": "^2.5.1",
        "@shopify/shopify-app-session-storage-prisma": "^4.0.1",
        "isbot": "^4.4.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@remix-run/dev": "^2.5.1",
        "@shopify/cli": "^3.93.2",
        "@types/react": "^18.2.55",
        "@types/react-dom": "^18.2.19",
        "prisma": "^5.9.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.2.2",
        "vite": "^5.1.0",
        "vite-tsconfig-paths": "^4.3.1"
    },
    "prisma": {
        "seed": "ts-node --esm prisma/seed.ts"
    },
    "workspaces": [
        "extensions/*"
    ]
}
